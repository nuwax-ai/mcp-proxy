### 测试向MySQL MCP服务发送消息
# @name sendMySqlMessage
POST http://localhost:8086/mcp/sse/proxy/{{mcp_id}}/message
Content-Type: application/json

{
  "id": "msg_123",
  "method": "completions.create",
  "params": {
    "messages": [
      {
        "role": "user",
        "content": "查询当前数据库中的所有表"
      }
    ]
  }
}



### 测试检查MySQL MCP服务状态（先检查服务状态）
# 示例: http://localhost:8086/mcp/sse/proxy/playwright-test-id/sse
# @name checkMySqlStatus
POST http://localhost:8086/mcp/sse/check_status
Content-Type: application/json

{
  "mcpId": "playwright-test-id",
  "mcpJsonConfig": "{\"mcpServers\":{\"playwright\":{\"command\":\"npx\",\"args\":[\"@playwright/mcp@latest\",\"--headless\"]}}}",
  "mcpType": "OneShot"
}



