# ============================================================================
# 通用变量与默认目标 (mk/common.mk)
# ============================================================================

# 默认目标平台 (单架构构建用)
TARGET_PLATFORM ?= linux/amd64

# Docker 镜像名称
IMAGE_NAME = mcp-proxy-builder

# 输出目录
OUTPUT_DIR = ./dist

# 裸 `make` (无参数) 时显示帮助，而不是自动构建某个目标
.DEFAULT_GOAL := help
